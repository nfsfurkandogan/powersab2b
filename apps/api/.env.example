APP_NAME="Powersa API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=powersa
DB_USERNAME=powersa
DB_PASSWORD=powersa

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REPORTS_QUEUE=reports

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=localhost
REDIS_PASSWORD=powersa
REDIS_PORT=6379
REDIS_USERNAME=default

MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=powersa
MEILISEARCH_ENABLED=true
MEILISEARCH_PRODUCTS_INDEX=products
MEILISEARCH_TIMEOUT=3
MEILISEARCH_QUEUE=default
MEILISEARCH_BATCH_SIZE=500

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

LOGO_CUSTOMER_SYNC_KEY=
LOGO_PRODUCT_SYNC_KEY=
LOGO_LEDGER_SYNC_KEY=
LOGO_COLLECTION_SYNC_KEY=
LOGO_POS_SALE_SYNC_KEY=
LOGO_POS_EXPENSE_SYNC_KEY=
LOGO_ORDER_SYNC_KEY=
LOGO_SHIPMENT_SYNC_KEY=
LOGO_RETURN_SYNC_KEY=
LOGO_WRITE_ENABLED=false
LOGO_WRITE_TRANSPORT=bridge
LOGO_WRITE_EXCHANGE=powersa.logo
LOGO_WRITE_RABBITMQ_HOST=127.0.0.1
LOGO_WRITE_RABBITMQ_PORT=5672
LOGO_WRITE_RABBITMQ_USER=guest
LOGO_WRITE_RABBITMQ_PASSWORD=guest
LOGO_WRITE_RABBITMQ_VHOST=/
LOGO_WRITE_RABBITMQ_HEARTBEAT=30
LOGO_WRITE_RABBITMQ_CONNECTION_TIMEOUT=3.0
LOGO_WRITE_RABBITMQ_READ_WRITE_TIMEOUT=3.0
POS_POINT_CASHBOX_CODE=100.01.007
POS_POINT_CASHBOX_NAME="ERZURUM POINT KASASI"

VITE_APP_NAME="${APP_NAME}"

TELESCOPE_ENABLED=true
TELESCOPE_QUERY_WATCHER_SLOW=200
PERF_ENDPOINT_LOG=false
