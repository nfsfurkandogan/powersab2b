LOGO_SQL_SERVER=GUCSASRV
LOGO_SQL_INSTANCE=LOGO
LOGO_SQL_PORT=
LOGO_SQL_DATABASE=LOGODB
LOGO_SQL_USER=sa
LOGO_SQL_PASSWORD=
LOGO_SQL_ENCRYPT=false
LOGO_SQL_TRUST_SERVER_CERTIFICATE=true
LOGO_SQL_REQUEST_TIMEOUT_MS=30000

# Logo Go Wings firma/donem kodlari. Bos tablo ayarlarinda scriptler bu
# degerlerden dbo.LG_002_CLCARD, dbo.LG_002_ITEMS, dbo.LG_002_01_CLFLINE
# gibi standart Logo tablo adlarini turetir.
LOGO_FIRM_NO=002
LOGO_PERIOD_NO=01

LOGO_CUSTOMER_TABLE=
LOGO_CUSTOMER_CARDTYPES=1,3
LOGO_PRODUCT_TABLE=
LOGO_PRODUCT_CARDTYPES=1
LOGO_LEDGER_SYNC_ENABLED=true
LOGO_LEDGER_TABLE=
LOGO_CUSTOMER_TOTAL_TABLE=
LOGO_CUSTOMER_FICHE_TABLE=
LOGO_PRODUCT_UNIT_TABLE=
LOGO_UNIT_SET_TABLE=
LOGO_UNIT_TABLE=
LOGO_PRODUCT_SUBSTITUTE_TABLE=
LOGO_STOCK_TABLE=
LOGO_PRICE_TABLE=
LOGO_STOCK_FICHE_TABLE=
LOGO_STOCK_LINE_TABLE=
LOGO_ORDER_FICHE_TABLE=
LOGO_ORDER_LINE_TABLE=
LOGO_INVOICE_TABLE=
LOGO_PAYMENT_TABLE=
LOGO_CASHBOX_TABLE=
LOGO_CASH_LINE_TABLE=
LOGO_BANK_TABLE=
LOGO_BANK_ACCOUNT_TABLE=
LOGO_BANK_FICHE_TABLE=
LOGO_BANK_LINE_TABLE=
LOGO_CHECK_NOTE_TABLE=
LOGO_SALESPERSON_TABLE=
LOGO_SALESPERSON_CUSTOMER_TABLE=
LOGO_SPECIAL_CODE_TABLE=
LOGO_WAREHOUSE_INFO_TABLE=
LOGO_LOCATION_TABLE=
# Standart Logo urun resimleri/dokumanlari dbo.LG_XXX_XX_PERDOC icinde
# INFOREF -> LG_XXX_ITEMS.LOGICALREF ve LDATA image/binary olarak tutulur.
# LOGO_PRODUCT_IMAGE_TABLE bos ise once LOGO_PRODUCT_DOCUMENT_TABLE, sonra
# firma/donem kodundan turetilen PERDOC/FIRMDOC/FOLDER adaylari denenir.
LOGO_PRODUCT_DOCUMENT_TABLE=
LOGO_PRODUCT_IMAGE_TABLE=
LOGO_PRODUCT_IMAGE_REF_COLUMN=
LOGO_PRODUCT_IMAGE_DATA_COLUMN=
LOGO_PRODUCT_IMAGE_PATH_COLUMN=
LOGO_PRODUCT_IMAGE_ORDER_COLUMN=
LOGO_PRODUCT_IMAGE_ROOT=
LOGO_PRODUCT_IMAGE_BASE_URL=
LOGO_PRODUCT_IMAGE_MAP_FILE=
LOGO_PRODUCT_IMAGE_FALLBACK_DIR=
# Raf Bilgileri tab'i ayri custom tabloda duruyorsa bu tabloyu verin.
# Desteklenen bag kolonlari: PARLOGREF, ITEMREF, CARDREF, STOCKREF, PRODUCTREF, INFOREF.
# Ornek alanlar: RAF25, RAF61, RAF55, RAF250, RAF995.
LOGO_PRODUCT_RAF_TABLE=
LOGO_PRODUCT_RAF_MAP_FILE=
# Raf'da deponun anahtar alanini (ör. "25", "61") depolarla eşlemek için kullanilir.
LOGO_WAREHOUSE_RAF_KEY_MAP=
# LOGO_OEM_TABLE=dbo.LG_XT1001_002
# LOGO_COMPETITOR_TABLE=dbo.LG_XT1001_002
LOGO_OEM_TABLE=
LOGO_COMPETITOR_TABLE=
LOGO_PRICE_PTYPE=

SYNC_BATCH_SIZE=500
SYNC_FORCE_FULL=false
SYNC_RESUME=true
SYNC_RETRY_MAX=3
SYNC_RETRY_BASE_DELAY_MS=3000
SYNC_STATE_FILE=.sync-state/products-sync-state.json
SYNC_FAILED_FILE=.sync-state/products-sync-failed.jsonl
SYNC_LOG_DIR=logs
SYNC_DISABLE_LOCK=false
SYNC_CONTINUE_ON_ERROR=false
SYNC_LEDGER_STATE_FILE=.ledger-sync-state.json

# Hizli stok otomasyonu: son hareket goren urunleri STLINE/STFICHE uzerinden
# bulur, guncel stoklari summary/view tablosundan okur ve minimum stock_only
# payload gonderir. Full repair stock sync'ten ayri state dosyasi kullanir.
SYNC_PRODUCTS_STOCK_FAST=false
SYNC_PRODUCTS_STOCK_INCREMENTAL=false
SYNC_PRODUCTS_STOCK_LOOKBACK_MINUTES=10
SYNC_PRODUCTS_STOCK_SKIP_MOVEMENT_FALLBACK=true
SYNC_PRODUCTS_STOCK_REQUIRE_SUMMARY_ROW=true
SYNC_PRODUCTS_STOCK_STATE_FILE=.sync-state/products-stock-fast-state.json
SYNC_PRODUCTS_STOCK_INCLUDE_PRICE=false

# Hizli katalog otomasyonu: son degisen/yeni urunlerin yaninda eski LOGICALREF
# araliklarini da parca parca gezer. Eski kartta yapilan ad/raf/OEM gibi
# degisikliklerin gece full sync beklemeden B2B'ye dusmesini saglar.
SYNC_PRODUCTS_CATALOG_INCREMENTAL=false
SYNC_PRODUCTS_CATALOG_LOOKBACK_MINUTES=10080
SYNC_PRODUCTS_CATALOG_RECENT_LIMIT=1000
SYNC_PRODUCTS_CATALOG_ROLLING_LIMIT=1000
SYNC_PRODUCTS_CATALOG_STATE_FILE=.sync-state/products-catalog-fast-state.json
# Belirli Logo urunlerini katalog payload'i ile tekrar gondermek icin.
# Ornek: SYNC_PRODUCTS_TARGET_REFS=13941,9123
# Ornek: SYNC_PRODUCTS_TARGET_CODES=CS 0040,70 800
SYNC_PRODUCTS_TARGET_REFS=
SYNC_PRODUCTS_TARGET_CODES=

# Logo GO Wings image-only sync. Canli firma 003 ornegi icin FIRMDOC genelde
# firma genel dokuman tablosudur; INFOREF urun LOGICALREF ile eslesir.
# Gercek degerleri .env icinde kurulumunuza gore yazin.
# LOGO_PRODUCT_IMAGE_TABLE=dbo.LG_003_FIRMDOC
# LOGO_PRODUCT_IMAGE_REF_COLUMN=INFOREF
# LOGO_PRODUCT_IMAGE_DATA_COLUMN=LDATA
# LOGO_PRODUCT_IMAGE_ORDER_COLUMN=LREF
SYNC_PRODUCT_IMAGE_OPTIMIZE=true
SYNC_PRODUCT_IMAGE_MAX_WIDTH=1200
SYNC_PRODUCT_IMAGE_JPEG_QUALITY=80
SYNC_PRODUCT_IMAGE_TARGET_MAX_BYTES=1500000
SYNC_PRODUCT_IMAGE_OUTPUT_FORMAT=jpeg
SYNC_PRODUCT_IMAGE_ALLOW_ORIGINAL_IF_SMALL=true
SYNC_PRODUCT_IMAGE_ORIGINAL_MAX_BYTES=1500000

# Surekli bridge modu. Kama'daki servis modeline benzer sekilde tek seferlik
# scriptleri saniyelik dongude calistirir. Hizli adimlar Logo/B2B degisikliklerini
# kisa aralikla yakalar, urun tam senkronu daha agir oldugu icin yavas dongudedur.
SYNC_DAEMON_FAST_INTERVAL_MS=3000
SYNC_DAEMON_SLOW_INTERVAL_MS=300000
SYNC_DAEMON_ERROR_BACKOFF_MS=30000
SYNC_DAEMON_FAST_STEPS=customers,ledger,customers-export,collections,pos-sales,pos-expenses,documents-export
SYNC_DAEMON_SLOW_STEPS=product-stocks
# Sadece stok/fiyat dongusu istenirse slow steps icinde product-stocks kullanilabilir.
# SYNC_DAEMON_SLOW_STEPS=product-stocks

